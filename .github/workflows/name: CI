name: CI

on:
  push:
    branches: [ "master" ]
  pull_request:
    branches: [ "master" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      # 1. Checkout repository
      - name: Checkout repository
        uses: actions/checkout@v4

      # 2. إعداد بيئة JDK (لو مشروعك Java/Gradle)
      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      # 3. بناء المشروع
      - name: Build with Gradle
        run: ./gradlew build

      # 4. تشغيل الاختبارات
      - name: Run tests
        run: ./gradlew test

      # 5. رفع الـ Artifact (مثلاً ملف JAR أو APK)
      - name: Upload build artifacts
        uses: actions/upload-artifact@v4
        with:
          name: build-output
          path: build/libs/*.jar
- name: Set up Node.js
  uses: actions/setup-node@v4
  with:
    node-version: '18'

- name: Install dependencies
  run: npm install

- name: Run build
  run: npm run build

- name: Run tests
  run: npm test
